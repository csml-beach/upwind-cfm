{
  "dataset": "cifar10",
  "dataset_kwargs": {
    "data_root": "data",
    "download": true
  },
  "method": "iso_fm_finite_difference",
  "method_kwargs": {
    "weight": 0.1
  },
  "pairing": "independent",
  "variant": "iso_fd_w01",
  "model": "unet2d",
  "model_kwargs": {
    "image_shape": [3, 32, 32],
    "base_channels": 128,
    "channel_mults": [1, 2, 2, 4],
    "num_res_blocks": 2,
    "time_dim": 256,
    "attention_resolutions": [16]
  },
  "seed": 0,
  "device": "cuda",
  "solver": "euler",
  "train": {
    "batch_size": 64,
    "max_steps": 100000,
    "log_every": 100,
    "checkpoint_every": 1000,
    "sample_every": 5000,
    "lr": 0.0002,
    "grad_clip": 1.0,
    "amp": true,
    "resume": true
  },
  "eval": {
    "n_eval": 256,
    "fid_n_eval": 2048,
    "nfe_values": [5, 10, 20, 50],
    "sample_grid_n": 64,
    "sample_grid_nrow": 8,
    "sample_grid_steps": 10,
    "compute_fid_kid": true,
    "eval_seed": 1234,
    "plot_seed": 1234
  },
  "out_dir": "results/cifar10_low_nfe/local/runs",
  "run_name": "cifar10_iso_fd_w01_seed0"
}
