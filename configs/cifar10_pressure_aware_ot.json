{
  "dataset": "cifar10",
  "dataset_kwargs": {
    "data_root": "data",
    "download": true
  },
  "method": "standard_cfm",
  "method_kwargs": {},
  "pairing": "pressure_aware_minibatch_ot",
  "pairing_kwargs": {
    "pressure_beta": 0.2,
    "pressure_t": "random",
    "reference_pairing": "minibatch_ot",
    "cost_feature": "downsampled_pixels",
    "image_shape": [3, 32, 32],
    "downsample_size": 8
  },
  "variant": "pressure_aware_ot",
  "model": "unet2d",
  "model_kwargs": {
    "image_shape": [3, 32, 32],
    "base_channels": 128,
    "channel_mults": [1, 2, 2, 4],
    "num_res_blocks": 2,
    "time_dim": 256,
    "attention_resolutions": [16]
  },
  "seed": 0,
  "device": "cuda",
  "solver": "euler",
  "train": {
    "batch_size": 64,
    "max_steps": 100000,
    "log_every": 100,
    "checkpoint_every": 1000,
    "sample_every": 5000,
    "lr": 0.0002,
    "grad_clip": 1.0,
    "amp": true,
    "resume": true
  },
  "eval": {
    "n_eval": 256,
    "fid_n_eval": 2048,
    "nfe_values": [5, 10, 20, 50],
    "sample_grid_n": 64,
    "sample_grid_nrow": 8,
    "sample_grid_steps": 10,
    "compute_fid_kid": true,
    "eval_seed": 1234,
    "plot_seed": 1234
  },
  "out_dir": "results/cifar10_low_nfe/local/runs",
  "run_name": "cifar10_pressure_aware_ot_seed0"
}
